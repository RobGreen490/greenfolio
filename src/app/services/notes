import { Injectable } from "@angular/core";
import { DrawableMode } from "../types/drawable-mode.type";

@Injectable({
  providedIn: 'root'
})
export class BackgroundColorService{

  backgroundColor = "#fff";
  newBackgroundColor = this.backgroundColor;

  determineBackgroundColor(currentDrawable: DrawableMode){
    switch(currentDrawable){
      case 'sine-waves':
        this.backgroundColor = "#0D0E12";
        break;
      case 'bouncing-circles':
        this.backgroundColor = "#0D0E12";
        break;
      case 'mouse-draw':
        this.backgroundColor = "#b0b0b0";
        break;
      default:
        this.backgroundColor = "#b0b0b0";
        break;
    }
  }

    //const newBackgroundColor = this.backgroundColorService.determineBackgroundColor(this.currentDrawable);
  toggleCanvasBGC(canvas: HTMLCanvasElement,currentDrawable: DrawableMode){
    this.determineBackgroundColor(currentDrawable);
    canvas.style.backgroundColor = this.backgroundColor;
  }
}
